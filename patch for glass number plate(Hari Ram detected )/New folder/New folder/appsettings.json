{
  "Logging": {
    "LogLevel": {
      "Default": "Error"
    }
  },
  "Serilog": {
    "Using": [],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "retainedFileCountLimit": "1"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Paths": {
    "ffmpeg": "./ffmpeg",
    "SqlScripts": "DatabaseScripts",
    "PgDump": ".././pgsql/bin/pg_dump.exe",
    "PsqlPath": ".././pgsql/bin/psql.exe",
    "restorePgSqlFilePath": ".././pgsql/bin/pg_restore.exe",
    "restorePgSqlFilePathLinux": ".././pgsql/bin/pg_restore",
    "EventImagesDirectory": "",
    "PgDumpLinux": ".././pgsql/bin/pg_dump",
    "PsqlPathLinux": ".././pgsql/bin/psql"
  },
  "ConnectionStrings": {
